# ---------------------------------------------------------------------------
# Python bytecode / caches
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---------------------------------------------------------------------------
# Packaging / build
# ---------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
MANIFEST
pip-wheel-metadata/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.cache/
coverage.xml
*.cover
.hypothesis/

# ---------------------------------------------------------------------------
# Type checkers / linters
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Editor tmp / swap artifacts
*.tmp.*

# ---------------------------------------------------------------------------
# Local agent / tooling settings
# ---------------------------------------------------------------------------
.claude/
.codex/

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# Pipeline outputs — all per-run artifacts live here and are re-creatable
# ---------------------------------------------------------------------------
outputs/**
artifacts/
# Override: keep the bundled demo predictions committed so the README
# recipes (plot_calibration / plot_signal / metrics / construct_portfolio)
# run end-to-end against the bundled fixtures without re-training.
!outputs/
!outputs/density_model_yahoo_next_step_ensemble_v1/
!outputs/density_model_yahoo_next_step_ensemble_v1/predictions.csv
!outputs/density_model_yahoo_next_step_ensemble_v1/ensemble/
!outputs/density_model_yahoo_next_step_ensemble_v1/ensemble/ensemble_manifest.json
!outputs/density_model_yahoo_next_step_ensemble_v1/ensemble/estimator_*/
!outputs/density_model_yahoo_next_step_ensemble_v1/ensemble/estimator_*/training_manifest.json
!outputs/benchmarks/
!outputs/benchmarks/*/
!outputs/benchmarks/*/predictions.csv

# ---------------------------------------------------------------------------
# Data — generated or user-owned datasets
# Commit curated fixtures intentionally; do NOT commit raw dumps or PII.
# ---------------------------------------------------------------------------
data/*.csv
data/synthetic/
data/raw/
data/interim/
*.parquet
*.pq
*.pt
# Override: keep the bundled demo fixtures committed alongside the panel
# configs so the README recipe and example runs are self-contained.
!data/train_features.csv
!data/val_features.csv
!data/predict_features.csv
!tests/**/*.pt

# ---------------------------------------------------------------------------
# TensorBoard / Optuna stores
# ---------------------------------------------------------------------------
events.out.tfevents.*
*.db

# ---------------------------------------------------------------------------
# Local scratch path accidentally created from editor navigation
# ---------------------------------------------------------------------------
mnt/
